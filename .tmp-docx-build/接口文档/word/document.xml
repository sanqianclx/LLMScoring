<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<w:document xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:w15="http://schemas.microsoft.com/office/word/2012/wordml" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 wp14">
  <w:body>
    <w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t>接口文档</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">本文档描述当前后端 REST API。接口统一由 Spring Boot 提供，基础路径为 `/api`。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>1. 基本说明</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 协议：HTTP</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 数据格式：`application/json`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 认证方式：当前版本为演示型实现，教师登录后由前端保存教师 ID，接口本身未接入正式 Token 认证</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 错误处理：接口异常会返回 HTTP 4xx/5xx，并附带错误消息</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>2. 接口列表</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>2.1 系统初始化</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">#### `GET /api/bootstrap`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：获取系统初始化展示信息。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">响应示例字段：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `message`：初始化提示信息</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `demoTeacher`：演示教师信息</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `demoShareCode`：演示试卷分享码</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teachers`：当前系统中的教师列表</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>2.2 教师账号相关</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">#### `POST /api/teachers/register`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：注册教师账号。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">请求体：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">{</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;name&quot;: &quot;张老师&quot;,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;username&quot;: &quot;zhang@example.com&quot;,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;password&quot;: &quot;123456&quot;,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;school&quot;: &quot;实验中学&quot;,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;taughtCourse&quot;: &quot;高中生物, 高中化学&quot;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">}</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">字段说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `name`：教师姓名</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `username`：用户名，当前也被前端当作邮箱使用</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `password`：密码</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `school`：所属学校</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `taughtCourse`：任教课程，当前为逗号分隔字符串</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">响应体：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">{</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;id&quot;: &quot;uuid&quot;,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;name&quot;: &quot;张老师&quot;,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;username&quot;: &quot;zhang@example.com&quot;,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;school&quot;: &quot;实验中学&quot;,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;taughtCourse&quot;: &quot;高中生物, 高中化学&quot;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">}</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">常见错误：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `409 Conflict`：用户名已存在</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `400 Bad Request`：必填项为空</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">#### `POST /api/teachers/login`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：教师登录。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">请求体：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">{</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;username&quot;: &quot;teacher&quot;,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;password&quot;: &quot;teacher123&quot;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">}</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">响应体：返回完整教师工作台数据，结构与 `GET /api/teachers/{teacherId}/dashboard` 相同。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">常见错误：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `401 Unauthorized`：用户名或密码错误</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">#### `GET /api/teachers/{teacherId}/dashboard`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：获取教师工作台数据。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">路径参数：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teacherId`：教师 ID</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">响应体结构：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">{</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;teacher&quot;: { &quot;id&quot;: &quot;uuid&quot;, &quot;name&quot;: &quot;林老师&quot;, &quot;username&quot;: &quot;teacher&quot;, &quot;school&quot;: &quot;星火中学&quot;, &quot;taughtCourse&quot;: &quot;高中生物&quot; },</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;courses&quot;: [],</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;papers&quot;: [],</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;submissions&quot;: [],</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;stats&quot;: {</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">    &quot;courseCount&quot;: 1,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">    &quot;paperCount&quot;: 1,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">    &quot;submissionCount&quot;: 3,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">    &quot;reviewedCount&quot;: 1,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">    &quot;pendingCount&quot;: 2</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  }</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">}</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">#### `PUT /api/teachers/{teacherId}`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：修改教师资料。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">路径参数：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teacherId`：教师 ID</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">请求体：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">{</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;name&quot;: &quot;林老师&quot;,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;school&quot;: &quot;星火中学&quot;,</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">  &quot;taughtCourse&quot;: &quot;高中生物, 竞赛生物&quot;</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">}</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">说明：所有字段均可选，不传则保持原值。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">响应体：返回修改后的教师信息。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>2.3 课程管理</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">#### `POST /api/teachers/{teacherId}/courses`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：创建课程。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">路径参数：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teacherId`：教师 ID</w:t></w:r></w:p>
