<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<w:document xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:w15="http://schemas.microsoft.com/office/word/2012/wordml" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 wp14">
  <w:body>
    <w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t>数据库设计文档</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">本文档说明本项目当前 MySQL 数据库的设计方案，包含数据库总体说明、表结构设计、表间关系、索引设计以及后续优化建议。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>1. 数据库概述</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>1.1 数据库名称</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `llm_scoring`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>1.2 数据库用途</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">本数据库用于支撑“基于 LLM 的自动评分系统”的核心业务，主要保存以下数据：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 教师账号信息</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 课程信息</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 试卷信息</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 题目信息</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 题目评分点信息</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 学生提交记录</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 学生答案内容</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 自动评分结果</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 教师审核后的最终评分结果</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 评分命中点与失分点明细</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>1.3 字符集设置</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">在初始化脚本中使用：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 字符集：`utf8mb4`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 排序规则：`utf8mb4_unicode_ci`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">该配置可以较好支持中文、英文及常见符号存储。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>2. 设计目标</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">本数据库设计遵循以下原则：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">1. 满足教师建课、建卷、分享、审核和学生答题、查分的完整业务流程。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">2. 尽量采用规范化多表设计，避免把复杂业务结构直接序列化到单字段中。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">3. 保留自动评分和人工审核两个阶段的数据，便于结果追踪和后续扩展。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">4. 通过主键、外键和索引支撑常见查询场景。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">5. 与当前 JPA 实体结构保持一致，便于代码与数据库一一对应。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>3. E-R 关系概览</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">系统核心实体关系如下：</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 一个教师可以拥有多个课程。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 一个教师可以拥有多张试卷。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 一个课程下可以有多张试卷。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 一张试卷下可以有多道题目。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 一道题目下可以有多个评分点。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 一张试卷可以对应多个学生提交。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 一次学生提交可以包含多个答案。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 一次学生提交可以包含多个单题评分记录。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 一条单题评分记录可以包含多个评分点明细。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">可以概括为：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teachers 1 - n courses`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teachers 1 - n papers`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `courses 1 - n papers`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `papers 1 - n questions`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `questions 1 - n question_scoring_points`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `papers 1 - n submissions`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submissions 1 - n submission_answers`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submissions 1 - n submission_question_scores`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submission_question_scores 1 - n submission_score_points`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>4. 表结构设计</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>4.1 `teachers`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：保存教师账号与基础资料。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">字段说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`：主键，教师 ID，`VARCHAR(36)`，使用 UUID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `name`：教师姓名。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `username`：登录用户名，唯一。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `password`：教师密码，当前版本为明文存储。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `school`：所属学校。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `taught_course`：任教课程描述，当前以字符串形式保存。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `created_at`：创建时间。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">主键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">唯一约束：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `username`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">设计说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 该表是教师端所有业务数据的根节点。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 当前版本未拆分角色表与权限表，适用于课程项目阶段。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>4.2 `courses`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：保存课程信息。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">字段说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`：主键，课程 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teacher_id`：所属教师 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `name`：课程名称。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `description`：课程描述。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `created_at`：课程创建时间。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">主键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">外键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teacher_id -&gt; teachers.id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">索引：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_courses_teacher_id (teacher_id)`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">设计说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 课程作为教师管理试卷的组织维度。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 当前一个课程只归属一个教师，适合当前单教师管理模式。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>4.3 `papers`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：保存试卷主信息。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">字段说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`：主键，试卷 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teacher_id`：所属教师 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `course_id`：所属课程 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `title`：试卷标题。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `description`：试卷说明。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `share_code`：试卷分享码，唯一。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `active`：试卷是否开放。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `created_at`：创建时间。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `updated_at`：更新时间。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">主键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">外键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teacher_id -&gt; teachers.id`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `course_id -&gt; courses.id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">唯一约束：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `share_code`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">索引：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_papers_teacher_id (teacher_id)`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_papers_course_id (course_id)`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">设计说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 教师端通过试卷完成题目录入与分享。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `share_code` 是学生访问试卷的核心入口，因此设置唯一约束。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>4.4 `questions`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：保存试卷下的题目。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">字段说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`：主键，题目 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `paper_id`：所属试卷 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `type`：题型，当前为 `FILL_BLANK` 或 `SHORT_ANSWER`。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `text`：题目内容。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `reference_answer`：参考答案。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `max_score`：题目满分。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `sort_order`：题目顺序。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">主键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">外键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `paper_id -&gt; papers.id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">索引：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_questions_paper_id (paper_id)`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">设计说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 将题目从试卷主表中拆出，便于支持多题结构。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `sort_order` 用于保证前端展示和评分时的题目顺序一致。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>4.5 `question_scoring_points`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：保存题目的评分点配置。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">字段说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`：主键，评分点 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `question_id`：所属题目 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `keyword`：关键词或别名表达式。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `score`：该评分点的分值。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `description`：评分点说明。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `sort_order`：评分点顺序。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">主键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">外键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `question_id -&gt; questions.id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">索引：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_scoring_points_question_id (question_id)`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">设计说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 评分点从题目表中拆分出来，便于一个题目配置多个得分点。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `keyword` 支持多个别名写法，当前后端通过分隔符做拆分匹配。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>4.6 `submissions`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：保存学生提交主记录。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">字段说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`：主键，提交记录 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `paper_id`：所属试卷 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teacher_id`：归属教师 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `course_id`：归属课程 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `share_code`：提交时使用的分享码。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `student_id`：学生学号。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `student_name`：学生姓名。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `auto_total`：自动评分总分。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `final_total`：最终评分总分。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `overall_feedback`：整体评语。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `status`：提交状态，当前为 `PENDING_REVIEW` 或 `REVIEWED`。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submitted_at`：提交时间。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `reviewed_at`：审核时间。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">主键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">外键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `paper_id -&gt; papers.id`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teacher_id -&gt; teachers.id`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `course_id -&gt; courses.id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">索引：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_submissions_teacher_id (teacher_id)`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_submissions_share_student_time (share_code, student_id, submitted_at)`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">设计说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 该表是学生答卷与评分结果的主入口。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 联合索引用于支持“按分享码 + 学号查询最近一次结果”的业务场景。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>4.7 `submission_answers`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：保存学生每道题的原始答案。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">字段说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`：主键，答案记录 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submission_id`：所属提交记录 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `question_id`：题目 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `answer_text`：学生答案内容。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `sort_order`：题目顺序。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">主键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">外键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submission_id -&gt; submissions.id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">索引：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_submission_answers_submission_id (submission_id)`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">设计说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 这里没有对 `question_id` 建外键约束到 `questions.id`。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 这样设计的原因是：即使后续教师修改或删除试卷题目，历史提交记录仍能保留原始作答信息，避免因题目变动导致历史数据失效。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>4.8 `submission_question_scores`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：保存单题评分结果。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">字段说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`：主键，评分记录 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submission_id`：所属提交记录 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `question_id`：题目 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `phase`：评分阶段，当前为 `AUTO` 或 `FINAL`。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `score`：本题得分。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `max_score`：本题满分。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `comment`：评语。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `rationale`：评分依据。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `overridden`：是否被教师覆盖修改。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `sort_order`：题目顺序。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">主键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">外键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submission_id -&gt; submissions.id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">索引：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_submission_scores_submission_id (submission_id)`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">设计说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `phase` 字段用于区分自动评分结果和最终评分结果。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 同一题目会保留两类评分数据：</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">  - `AUTO`：系统自动评分</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">  - `FINAL`：教师审核后的最终评分</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `overridden` 用于标记该题是否被教师人工调整过。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>4.9 `submission_score_points`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">作用：保存单题评分中的命中点和失分点明细。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">字段说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`：主键，评分点明细 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `question_score_id`：所属单题评分记录 ID。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `point_text`：评分点文本。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `point_kind`：评分点类型，当前为 `MATCHED` 或 `MISSING`。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `sort_order`：排序字段。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">主键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">外键：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `question_score_id -&gt; submission_question_scores.id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">索引：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_submission_score_points_score_id (question_score_id)`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">设计说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 该表把“命中了哪些得分点”“缺失了哪些得分点”拆出来单独存储。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 便于前端高亮展示命中与失分原因，也为后续做统计分析预留了空间。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>5. 主外键关系汇总</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">| 主表 | 子表 | 关系 | 说明 |</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">| --- | --- | --- | --- |</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">| `teachers` | `courses` | 1 对多 | 一个教师可创建多个课程 |</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">| `teachers` | `papers` | 1 对多 | 一个教师可创建多张试卷 |</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">| `courses` | `papers` | 1 对多 | 一个课程下可包含多张试卷 |</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">| `papers` | `questions` | 1 对多 | 一张试卷下可有多道题目 |</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">| `questions` | `question_scoring_points` | 1 对多 | 一道题可有多个评分点 |</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">| `papers` | `submissions` | 1 对多 | 一张试卷可有多个学生提交 |</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">| `submissions` | `submission_answers` | 1 对多 | 一次提交可包含多个答案 |</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">| `submissions` | `submission_question_scores` | 1 对多 | 一次提交可包含多个评分结果 |</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">| `submission_question_scores` | `submission_score_points` | 1 对多 | 一条评分记录可包含多个评分点明细 |</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>6. 索引设计说明</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">当前数据库主要索引及其用途如下：</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>6.1 课程相关索引</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_courses_teacher_id`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">  作用：支持教师工作台按教师查询课程列表。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>6.2 试卷相关索引</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_papers_teacher_id`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">  作用：支持按教师查询试卷列表。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_papers_course_id`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">  作用：支持按课程查询试卷列表。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `share_code` 唯一索引</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">  作用：支持学生按分享码快速访问试卷。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>6.3 提交相关索引</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_submissions_teacher_id`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">  作用：支持教师按自身查看学生提交记录。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_submissions_share_student_time`</w:t></w:r></w:p>
    <w:p><w:r><w:t xml:space="preserve">  作用：支持学生按分享码和学号查询最近一次成绩结果。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>6.4 子表索引</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_questions_paper_id`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_scoring_points_question_id`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_submission_answers_submission_id`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_submission_scores_submission_id`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `idx_submission_score_points_score_id`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">这些索引用于提升级联读取性能，减少按主记录查询子记录时的扫描成本。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>7. 与 JPA 实体的对应关系</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">当前数据库表与后端实体一一对应：</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `teachers` 对应 `TeacherEntity`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `courses` 对应 `CourseEntity`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `papers` 对应 `PaperEntity`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `questions` 对应 `QuestionEntity`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `question_scoring_points` 对应 `ScoringPointEntity`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submissions` 对应 `SubmissionEntity`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submission_answers` 对应 `SubmissionAnswerEntity`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submission_question_scores` 对应 `SubmissionQuestionScoreEntity`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `submission_score_points` 对应 `SubmissionScorePointEntity`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">这意味着：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 数据库结构和后端持久化代码保持一致。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• JPA 可以直接完成实体与表之间的映射。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• 后续维护数据库结构时，也应同步更新实体类与初始化脚本。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>8. 设计优点</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">当前数据库设计的主要优点：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">1. 结构规范，试卷、题目、评分点、提交、评分结果均独立拆表。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">2. 自动评分与最终评分分离，便于保留评分过程和审核痕迹。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">3. 历史提交数据与试卷结构解耦，能降低后续修改试卷时对历史记录的影响。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">4. 可以支持教师端、学生端和评分模块的主要业务查询。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">5. 适合当前课程项目、毕设项目或小型教学系统原型使用。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>9. 当前不足与优化方向</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>9.1 当前不足</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">1. 教师密码仍为明文存储，安全性不足。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">2. `taught_course` 仍为字符串字段，没有进一步拆成规范化多表。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">3. 学生当前未单独建表，学生身份通过提交记录中的 `student_id` 和 `student_name` 表示。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">4. 缺少操作日志表、审核历史表、权限角色表等更完整的工程化设计。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">5. 部分分数字段使用 `DOUBLE`，若后续对精度要求更高，可改为 `DECIMAL`。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading3"/></w:pPr><w:r><w:t>9.2 后续优化建议</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">1. 增加密码加密存储，例如 BCrypt。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">2. 新增 `students` 表，统一维护学生信息。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">3. 新增 `teacher_roles`、`permissions` 等权限控制表。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">4. 增加 `review_logs` 表，记录每次教师审核修改历史。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">5. 对成绩字段改用 `DECIMAL(5,2)` 等更稳定的数值类型。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">6. 结合 Flyway 或 Liquibase 做数据库版本管理。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">7. 若后续接入真实 LLM，可增加 `llm_score_logs` 表，记录模型输入输出和评分版本。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>10. 初始化脚本说明</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">当前数据库初始化相关文件：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `src/main/resources/schema.sql`</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `database/mysql-init.sql`</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">说明：</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `schema.sql` 用于 Spring Boot 启动时初始化表结构。</w:t></w:r></w:p>
    <w:p><w:pPr><w:pStyle w:val="ListParagraph"/></w:pPr><w:r><w:t xml:space="preserve">• `mysql-init.sql` 用于手动初始化 MySQL 数据库与表结构。</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">推荐初始化命令：</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="CodeBlock"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas" w:hAnsi="Consolas" w:eastAsia="Consolas"/><w:sz w:val="20"/></w:rPr><w:t xml:space="preserve">mysql -uroot -p123456 &lt; D:\idealcode\LLMScoring\database\mysql-init.sql</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>11. 总结</w:t></w:r></w:p>
    <w:p/>
    <w:p><w:r><w:t xml:space="preserve">本项目数据库采用面向业务流程的规范化设计，已经能够支撑教师建课建卷、学生答题、自动评分、教师审核和成绩发布等完整场景。当前结构适合作为教学项目和毕业设计项目的数据库基础版本，后续可以在安全性、权限体系、日志记录和扩展能力方面继续增强。</w:t></w:r></w:p>
